<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileSystem.UI.ViewModels"
        x:Class="FileSystem.UI.Views.FolderSelectDialog"
        x:DataType="vm:FolderSelectDialogViewModel"
        Title="Выберите папку для перемещения"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Design.DataContext>
        <vm:FolderSelectDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto" Margin="15">
        <TextBlock Grid.Row="0" Text="Выберите целевую папку:" Margin="0,0,0,10" FontWeight="SemiBold"/>
        
        <TreeView Grid.Row="0" 
                  ItemsSource="{Binding AvailableFolders}" 
                  SelectedItem="{Binding SelectedFolder}"
                  Margin="0,25,0,15">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📁"/>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Location, StringFormat='({0})'}" Foreground="#888" FontSize="11"/>
                    </StackPanel>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button x:Name="CancelButton" Content="Отмена" Padding="15,5" MinWidth="100"/>
            <Button x:Name="OkButton" Content="OK" Padding="15,5" MinWidth="100" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>